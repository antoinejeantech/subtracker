# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                (this file) — committed defaults and documentation
#  * .env.local          — local overrides, never committed (gitignored)
#  * .env.$APP_ENV       — environment-specific defaults (e.g. .env.dev)
#  * .env.$APP_ENV.local — environment-specific local overrides (gitignored)
#
# Real environment variables always win over .env files.
# DO NOT put production secrets in this file. Use .env.local instead.

###> symfony/framework-bundle ###
APP_ENV=dev
# Generate a random 32-char hex string: openssl rand -hex 16
APP_SECRET=change_me
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Uses the "db" Docker service as host. Override to "localhost" when connecting from outside Docker.
DATABASE_URL="postgresql://app:app@db:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
# Generate key pair: make console c="lexik:jwt:generate-keypair"
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/mailer ###
# Use "null://null" to discard mail in development.
# Example SMTP: smtp://user:pass@localhost:587
MAILER_DSN=null://null
###< symfony/mailer ###
